# FourMore Environment Configuration
# This file contains defaults for local development
# Create .env.local (gitignored) to override with your actual secrets

# ============================================================================
# Local Development Configuration (Run services locally, not in Docker)
# ============================================================================

# Database (local PostgreSQL instance or managed service)
DATABASE_URL=postgresql://fourmore:fourmore_dev_password@localhost:5432/fourmore

# Redis (local Redis instance or managed service)
REDIS_URL=redis://localhost:6379

# Backend Configuration
DEBUG=true
ENVIRONMENT=development

# Logging
LOG_LEVEL=WARNING

# JWT Configuration
JWT_SECRET_KEY=your_super_secret_jwt_key_here_change_in_env_local
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=20160 # 14 days

# OpenStreetMap OAuth (register at https://www.openstreetmap.org/oauth2/applications)
# Use redirect URI: http://127.0.0.1:3000/auth/callback
OSM_CLIENT_ID=your_osm_client_id
OSM_CLIENT_SECRET=your_osm_client_secret
OSM_REDIRECT_URI=http://127.0.0.1:3000/auth/callback

# OSM Account Whitelist (for private beta)
# Leave empty to allow all users, or specify comma-separated usernames and/or user IDs
# Examples:
#   OSM_ALLOWED_USERNAMES=alice,bob,charlie
#   OSM_ALLOWED_USER_IDS=123456,789012,345678
# Note: Usernames are case-insensitive
OSM_ALLOWED_USERNAMES=
OSM_ALLOWED_USER_IDS=

# Frontend Configuration
VITE_API_BASE_URL=http://127.0.0.1:8000

# ============================================================================
# Docker/Production Configuration (used when deploying containers)
# ============================================================================

# Database (for containerized deployments)
POSTGRES_DB=fourmore
POSTGRES_USER=fourmore
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# For Docker Compose database service
DATABASE_NAME=fourmore
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=fourmore
DATABASE_PASSWORD=change_me_in_production

# Service Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
REDIS_PORT=6379

# ============================================================================
# OSM Data Pipeline Configuration
# ============================================================================
# OSM_DATASET controls the defaults used by helper scripts:
#   planet (default) - downloads the full planet extract
#   usa              - downloads the contiguous US extract
#   utah             - legacy state-sized extract for quick tests
OSM_DATASET=planet

# Override these to point scripts at a specific download target.
# HOST: used by scripts/download-osm.sh when saving into ./data
OSM_DOWNLOAD_FILE=planet-latest.osm.pbf
OSM_DOWNLOAD_URL=https://planet.openstreetmap.org/pbf/planet-latest.osm.pbf

# CONTAINER: path visible to the data-pipeline container after you copy or
# pre-filter the downloaded data into ./data (mounted at /app/data in Docker).
# For example, after running the prefilter you will usually point this at the
# filtered output (planet-pois-filtered.osm.pbf).
OSM_DATA_FILE=/app/data/planet-pois-filtered.osm.pbf
